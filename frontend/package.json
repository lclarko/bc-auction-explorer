{
  "name": "bc-auction-explorer-frontend",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "generate:api-schema": "python -m bc_auction.openapi --output src/api/schema.json",
    "generate:api-types": "npm run generate:api-schema && node scripts/generate-api-types.mjs",
    "check:api-types": "npm run generate:api-types && git diff --exit-code -- src/api/schema.json src/api/types.ts"
  },
  "dependencies": {
    "@date-fns/tz": "1.5.0",
    "@tanstack/react-query": "5.101.2",
    "openapi-fetch": "0.17.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-router-dom": "7.18.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.11.1",
    "@eslint/js": "9.39.1",
    "@playwright/test": "1.61.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.1",
    "globals": "16.5.0",
    "jsdom": "27.2.0",
    "msw": "2.15.0",
    "openapi-typescript": "7.13.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.49.0",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
