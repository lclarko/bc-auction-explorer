{
    http_port 8080
    https_port 8443
    admin off
}

{$BC_AUCTION_SITE_ADDRESS:http://:8080} {
    encode zstd gzip

    @operations path /health/operations
    handle @operations {
        respond "not found" 404
    }

    handle /api/* {
        reverse_proxy api:8000
    }

    handle /health/live {
        reverse_proxy api:8000
    }

    handle /health/ready {
        reverse_proxy api:8000
    }

    handle {
        reverse_proxy frontend:8080
    }
}
