# Non-secret production configuration. Keep the referenced password files outside this repository.
BC_AUCTION_VERSION=development
BC_AUCTION_GIT_COMMIT=unknown
BC_AUCTION_BUILD_TIMESTAMP=unknown
BC_AUCTION_DATABASE_NAME=bc_auction
BC_AUCTION_TIMEZONE=America/Vancouver
BC_AUCTION_SCRAPE_TIMES=06:00,12:00,18:00
BC_AUCTION_SCRAPE_LIMIT=1000
BC_AUCTION_SCRAPE_FRESHNESS_MAX_AGE_SECONDS=28800
BC_AUCTION_SCRAPE_MAX_RUN_SECONDS=7200
BC_AUCTION_LOG_LEVEL=INFO

# Loopback-only HTTP and HTTPS listeners. Public ingress is configured by deployment tooling.
BC_AUCTION_BIND_ADDRESS=127.0.0.1
BC_AUCTION_HTTP_PORT=8080
BC_AUCTION_HTTPS_PORT=8443
BC_AUCTION_SITE_ADDRESS=http://localhost:8080

# One password per file, with mode 0600 and ownership restricted to the deployment account.
BC_AUCTION_POSTGRES_ADMIN_PASSWORD_FILE=/etc/bc-auction-explorer/secrets/postgres_admin_password
BC_AUCTION_MIGRATION_PASSWORD_FILE=/etc/bc-auction-explorer/secrets/migration_password
BC_AUCTION_SCRAPER_PASSWORD_FILE=/etc/bc-auction-explorer/secrets/scraper_password
BC_AUCTION_API_PASSWORD_FILE=/etc/bc-auction-explorer/secrets/api_password
